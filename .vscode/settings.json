{

	"[css]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.stylelint": "explicit"
		},
		"editor.defaultFormatter": "stylelint.vscode-stylelint"
	},

	"[typescriptreact]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	// Disable the default CSS formatter, use stylelint instead
	"css.validate": false,

	// Auto fix
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"editor.defaultFormatter": "dbaeumer.vscode-eslint",
	"editor.formatOnSave": false,
	"editor.tabSize": 4,

	"eslint.format.enable": true,
	// Enable eslint for all supported languages
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"vue",
		"html",
		"markdown",
		"json",
		"jsonc",
		"yaml",
		"toml",
		"astro"
	],
	"eslint.workingDirectories": ["auto"],
	"files.eol": "\n",

	"less.validate": false,
	// Disable the default formatter, use eslint instead
	"prettier.enable": false,
	"scss.validate": false,

	"svg.preview.background": "custom",
	"typescript.tsdk": "./frontend/node_modules/typescript/lib",
	"workbench.editor.customLabels.enabled": true,

	"workbench.editor.customLabels.patterns": {
		"**/components/**/*.css": "${dirname} (${extname})",
		"**/components/**/*.js": "${dirname} (${extname})",
		"**/components/**/*.tsx": "${dirname} (${extname})"
	},
	"[javascript]": {
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"workbench.colorCustomizations": {
		"activityBar.activeBackground": "#b9b4b0",
		"activityBar.background": "#b9b4b0",
		"activityBar.foreground": "#15202b",
		"activityBar.inactiveForeground": "#15202b99",
		"activityBarBadge.background": "#28784b",
		"activityBarBadge.foreground": "#e7e7e7",
		"commandCenter.border": "#15202b99",
		"sash.hoverBorder": "#b9b4b0",
		"statusBar.background": "#a19a95",
		"statusBar.foreground": "#15202b",
		"statusBarItem.hoverBackground": "#89807a",
		"statusBarItem.remoteBackground": "#a19a95",
		"statusBarItem.remoteForeground": "#15202b",
		"titleBar.activeBackground": "#a19a95",
		"titleBar.activeForeground": "#15202b",
		"titleBar.inactiveBackground": "#a19a9599",
		"titleBar.inactiveForeground": "#15202b99"
	},
	"peacock.color": "#a19a95"

}
