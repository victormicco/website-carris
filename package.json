{
	"name": "@carrismetropolitana/website",
	"private": true,
	"scripts": {
		"build": "turbo build --filter=@carrismetropolitana/website-backoffice",
		"clean": "sh cleanup.sh",
		"dev": "dotenv-run -f ./configs/development/secrets/.env -- turbo dev",
		"dev:backoffice": "dotenv-run -f ./configs/development/secrets/.env -- turbo dev --filter=@carrismetropolitana/website-backoffice",
		"lint": "turbo lint --filter=@carrismetropolitana/website-backoffice",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250418.42.41",
		"@tmlmobilidade/tsconfig": "20250325.1731.13",
		"dotenv-cli": "8.0.0",
		"turbo": "2.5.2",
		"typescript": "5.8.3"
	},
	"packageManager": "npm@11.3.0",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"apps/*"
	]
}
