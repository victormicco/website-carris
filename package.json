{
	"name": "@carrismetropolitana/website",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"build:backoffice": "turbo build --filter=@carrismetropolitana/website-backoffice",
		"build:frontend": "turbo build --filter=@carrismetropolitana/website-frontend",
		"build:schools": "turbo build --filter=@carrismetropolitana/website-schools",
		"build:shared": "turbo build --filter=./shared/*",
		"dev": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev",
		"dev:backoffice": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@carrismetropolitana/website-backoffice",
		"dev:frontend": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@carrismetropolitana/website-frontend",
		"dev:schools": "dotenv-run -f ./environments/development/secrets/.env -- turbo dev --filter=@carrismetropolitana/website-schools",
		"lint": "turbo lint",
		"lint-fix": "turbo lint-fix",
		"lint:backoffice": "turbo lint --filter=@carrismetropolitana/website-backoffice",
		"lint:frontend": "turbo lint --filter=@carrismetropolitana/website-frontend",
		"lint:schools": "turbo lint --filter=@carrismetropolitana/website-schools",
		"rinse": "npx --yes @tmlmobilidade/repo-rinse",
		"start": "turbo start"
	},
	"devDependencies": {
		"@carrismetropolitana/eslint": "20250622.1204.50",
		"@dotenv-run/cli": "1.3.6",
		"turbo": "2.5.4",
		"typescript": "5.8.3"
	},
	"packageManager": "npm@11.4.2",
	"engines": {
		"node": ">=18"
	},
	"workspaces": [
		"shared/*",
		"apps/*"
	]
}
